{
  "name": "smalti",
  "productName": "Smalti",
  "version": "0.3.0",
  "description": "Smalti — a terminal-centric AI-driven IDE with natural-language plugin generation",
  "homepage": "https://github.com/Achelous1/smalti",
  "repository": {
    "type": "git",
    "url": "https://github.com/Achelous1/smalti.git"
  },
  "bugs": {
    "url": "https://github.com/Achelous1/smalti/issues"
  },
  "main": ".vite/build/index.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build:native": "node scripts/build-native.mjs",
    "build:native:universal": "node scripts/build-native.mjs --universal",
    "postinstall": "pnpm run build:native"
  },
  "keywords": [
    "electron",
    "ide",
    "ai",
    "plugin"
  ],
  "author": {
    "name": "Jinsu Ha",
    "email": "js.ha@actimedi.com"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller",
      "fs-xattr",
      "macos-alias"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@napi-rs/cli": "^3.6.2",
    "@playwright/test": "^1.50.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "41.0.3",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "@types/adm-zip": "^0.5.8",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "adm-zip": "^0.5.17",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  }
}
